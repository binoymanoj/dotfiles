{
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "fit-to-screen": false,
  "control-center-width": 380,
  "control-center-height": 0,
  "notification-window-width": 380,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "widgets": [
    "mpris",
    "calendar",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 6
    },
    "calendar": {
      "timezone": "local",
      "show-week-numbers": false
    }
  }
}
