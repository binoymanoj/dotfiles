{
  "layer": "top",
  "position": "top",
  "height": 36,
  "exclusive": true,
  "modules-left": [
    "custom/arch",
    "hyprland/workspaces",
    "hyprland/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "network",
    "bluetooth",
    "battery",
    "custom/notification"
  ],
  "custom/arch": {
    "format": "",
    "tooltip": false
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{id}",
    "on-click": "activate"
  },
  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true
  },
  "clock": {
    "format": "{:%I:%M %p | %d %a}",
    "tooltip": true,
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "cpu": {
    "format": "<span color='#cba6f7'>蟀粻</span> {usage}%",
    "interval": 2,
    "tooltip": true,
    "tooltip-format": "CPU: {usage}%\nLoad: {load}"
  },
  "memory": {
    "format": "<span color='#cba6f7'>蟀崨</span> {percentage}%",
    "interval": 2,
    "tooltip": true,
    "tooltip-format": "Used: {used:0.1f}GB / {total:0.1f}GB"
  },
  "network": {
    "format": "<span color='#cba6f7'>蟀嚉</span> {bandwidthDownBytes}",
    "format-disconnected": "<span color='#f38ba8'>蟀柂</span>",
    "interval": 1,
    "tooltip": true,
    "tooltip-format": "{essid} ({signalStrength}%)\n{ipaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click-right": "nm-applet"
  },
  "bluetooth": {
    "format": "<span color='#cba6f7'>蟀偗</span>",
    "format-disabled": "<span color='#555'>蟀偛</span>",
    "format-off": "<span color='#555'>蟀偛</span>",
    "format-connected": "<span color='#cba6f7'>蟀偙</span>",
    "tooltip": true,
    "tooltip-format": "{controller_alias}\n{num_connections} connected",
    "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}",
    "on-click": "blueman-manager"
  },
  "battery": {
    "interval": 5,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-charging": "<span color='#cba6f7'>蟀倓</span> {capacity}%",
    "format-plugged": "<span color='#cba6f7'>蟀倓</span> {capacity}%",
    "format-icons": [
      "<span color='#f38ba8'>蟀伜</span>",
      "<span color='#f9e2af'>蟀伝</span>",
      "<span color='#f9e2af'>蟀伡</span>",
      "<span color='#cba6f7'>蟀伣</span>",
      "<span color='#cba6f7'>蟀伨</span>",
      "<span color='#cba6f7'>蟀伩</span>",
      "<span color='#cba6f7'>蟀個</span>",
      "<span color='#cba6f7'>蟀倎</span>",
      "<span color='#cba6f7'>蟀倐</span>",
      "<span color='#cba6f7'>蟀伖</span>"
    ]
  },
  "custom/notification": {
    "format": "<span color='#cba6f7'>蟀倸</span>",
    "on-click": "swaync-client -t -sw",
    "tooltip": false
  }
}
